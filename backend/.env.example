PORT=8000
FRONTEND_URL=http://localhost:5173
GOOGLE_API_KEY=your_google_ai_studio_key
# Optional: SQLite URL for safe haven places (default: backend/data/safewander.db)
# DATABASE_URL=sqlite:////absolute/path/to/safewander.db
GOOGLE_GENAI_MODEL=gemini-3.1-flash-lite-preview
# Optional: model id (e.g. gemini-2.5-flash). Preview/thinking models may stream empty text; see README.
# GOOGLE_GENAI_MODEL=gemini-2.5-flash
# Thinking budget: 0 disables internal "thinking" tokens (default). Use -1 for model default.
# GOOGLE_GENAI_THINKING_BUDGET=0
